---
/**
 * EssayLayout — renders a single essay's markdown body (via <slot/>) inside
 * the design system, shows the epistemic-status marker when present, and
 * mounts the GuidePanel. Sets window context globals so the guide knows which
 * essay is on screen and can inject its live text.
 *
 * Used by src/pages/writing/[slug].astro. Essay pages prerender.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import GuidePanel from '@/components/GuidePanel.astro';

interface Props {
  title: string;
  slug: string;
  summary: string;
  date: Date;
  topics?: string[];
  epistemicStatus?: string;
  series?: string;
}

const { title, slug, summary, date, topics = [], epistemicStatus, series } = Astro.props;
const dateStr = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} — Tom Cassidy`} description={summary} currentPage="writing" withGuide={true}>
  <div class="essay-shell">
    <article class="essay">
      <header class="essay-header">
        <div class="essay-meta">
          <span>{dateStr}</span>
          {series && <span class="essay-series">{series}</span>}
          {topics.map((t) => <span class="essay-topic">#{t}</span>)}
        </div>
        <h1 class="essay-title">{title}</h1>
        <p class="essay-summary">{summary}</p>
        {epistemicStatus && (
          <div class="epistemic-marker" data-status={epistemicStatus}>
            <span class="marker-note">epistemic status</span>
            <span class={`pigment-chip is-${epistemicStatus}`}>{epistemicStatus}</span>
          </div>
        )}
      </header>

      <div class="essay-body">
        <slot />
      </div>
    </article>
  </div>

  <GuidePanel currentTitle={title} epistemicStatus={epistemicStatus} />

  {/* Publish the current essay to the guide. Set before the panel's logic
      reads it; the panel never auto-sends, so this just primes context. */}
  <script
    is:inline
    define:vars={{ slug, title, epistemicStatus: epistemicStatus ?? '' }}
  >
    window.currentSlug = slug;
    window.currentTitle = title;
    window.currentStatus = epistemicStatus || null;
    window.currentMode = 'essay';
  </script>
</BaseLayout>

<style>
  .essay-shell {
    /* Leave room for the fixed 400px guide panel on wide screens. */
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  @media (min-width: 1101px) {
    .essay-shell {
      margin-right: 440px;
    }
  }

  .essay-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 1.4rem;
  }
  .essay-series { color: var(--text-secondary); }
  .essay-topic { color: var(--text-muted); }

  .essay-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: clamp(2.1rem, 5vw, 3.2rem);
    font-weight: 440;
    letter-spacing: -0.015em;
    line-height: 1.06;
    color: var(--text-primary);
    margin-bottom: 1.1rem;
  }

  .essay-summary {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1.6rem;
    max-width: var(--measure);
  }

  .epistemic-marker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .marker-note { color: var(--text-muted); }

  .essay-body {
    margin-top: 2.75rem;
    font-family: var(--font-body);
    font-size: 1.18rem;
    line-height: 1.78;
    color: var(--text-primary);
    max-width: var(--measure);
  }

  /* Markdown content styling (global — content is injected via slot). */
  .essay-body :global(h2) {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: 1.85rem;
    font-weight: 460;
    color: var(--text-primary);
    margin: 2.75rem 0 1rem;
    line-height: 1.15;
  }
  .essay-body :global(h3) {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: 1.4rem;
    font-weight: 480;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
  }
  .essay-body :global(p) { margin-bottom: 1.4rem; }
  .essay-body :global(ul), .essay-body :global(ol) { margin: 0 0 1.4rem 1.5rem; }
  .essay-body :global(li) { margin-bottom: 0.45rem; }
  .essay-body :global(em) { font-style: italic; }
  .essay-body :global(strong) { color: var(--text-primary); font-weight: 600; }
  .essay-body :global(blockquote) {
    border-left: 4px solid var(--established);
    background: var(--established-wash);
    padding: 0.85rem 1.4rem;
    margin: 1.75rem 0;
    color: var(--text-secondary);
    font-style: italic;
    border-radius: 0 6px 6px 0;
  }
  .essay-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--border-soft);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }
  .essay-body :global(a) {
    color: var(--established);
    border-bottom: 1px solid color-mix(in srgb, var(--established) 45%, transparent);
    transition: border-color 0.2s;
  }
  .essay-body :global(a:hover) { border-bottom-color: var(--established); }
  .essay-body :global(hr) {
    border: none;
    border-top: 1px solid var(--hairline);
    margin: 2.5rem 0;
  }
</style>
