---
/**
 * NerdQuadrant.astro — The NERD quadrant — draggable food marker + live score (vanilla-script island).
 *
 * Self-contained imperative SVG/DOM viz, so it ships as a plain Astro <script>
 * island (no framework runtime) rather than a Svelte component — the lightest
 * tool for the job. The initial markup is server-rendered via set:html; the
 * script wires the interactions on the client. Every colour is a design token,
 * so it re-pigments with the site theme. Ported verbatim from the verified
 * prototype in prototypes/reasonable-eating-explorer.html (hence @ts-nocheck:
 * it is hand-written browser JS, not strict TypeScript).
 */
const HTML = "\n<div class=\"nerd-stage\">\n  <div class=\"nerd-plot-wrap\">\n    <svg class=\"nerd-plot\" viewBox=\"0 0 320 320\" role=\"application\"\n         aria-label=\"NERD quadrant. Drag the marker to set energy on the horizontal axis and nutrition on the vertical axis; the Nutrition-to-Energy Ratio score updates live.\">\n      <desc>A two-by-two plot. The horizontal axis is energy, low on the left to high on the right. The vertical axis is nutrition, low at the bottom to high at the top. The winning zone is the top-left: high nutrition for low energy.</desc>\n\n      <!-- win wash: top-left quadrant (low energy, high nutrition) -->\n      <rect class=\"win-cell\" x=\"48\" y=\"40\" width=\"112\" height=\"112\" rx=\"2\"/>\n\n      <!-- frame + cross axes -->\n      <rect class=\"frame\" x=\"48\" y=\"40\" width=\"224\" height=\"224\" rx=\"3\" fill=\"none\"/>\n      <line class=\"axis\" x1=\"160\" y1=\"40\"  x2=\"160\" y2=\"264\"/>\n      <line class=\"axis\" x1=\"48\"  y1=\"152\" x2=\"272\" y2=\"152\"/>\n\n      <!-- quarter ticks -->\n      <line class=\"axis-tick\" x1=\"104\" y1=\"262\" x2=\"104\" y2=\"266\"/>\n      <line class=\"axis-tick\" x1=\"216\" y1=\"262\" x2=\"216\" y2=\"266\"/>\n      <line class=\"axis-tick\" x1=\"46\"  y1=\"96\"  x2=\"50\"  y2=\"96\"/>\n      <line class=\"axis-tick\" x1=\"46\"  y1=\"208\" x2=\"50\"  y2=\"208\"/>\n\n      <!-- win label -->\n      <text class=\"win-label\" x=\"56\" y=\"55\">High NERD</text>\n\n      <!-- axis pole labels -->\n      <text class=\"axis-label\" x=\"48\"  y=\"280\" text-anchor=\"start\">Low</text>\n      <text class=\"axis-label\" x=\"272\" y=\"280\" text-anchor=\"end\">High</text>\n      <text class=\"axis-name\"  x=\"160\" y=\"293\" text-anchor=\"middle\">Energy · calories</text>\n\n      <text class=\"axis-label\" x=\"40\" y=\"44\"  text-anchor=\"end\">High</text>\n      <text class=\"axis-label\" x=\"40\" y=\"264\" text-anchor=\"end\">Low</text>\n      <text class=\"axis-name\"  x=\"20\" y=\"152\" text-anchor=\"middle\" transform=\"rotate(-90 20 152)\">Nutrition</text>\n\n      <!-- ghost food positions injected by JS -->\n      <g class=\"ghosts\"></g>\n\n      <!-- lead lines + marker injected/positioned by JS -->\n      <line class=\"lead-line lead-v\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"264\"/>\n      <line class=\"lead-line lead-h\" x1=\"48\" y1=\"0\" x2=\"0\" y2=\"0\"/>\n      <g class=\"marker tint-win\">\n        <circle class=\"marker-halo\" r=\"17\"/>\n        <circle class=\"marker-core\" r=\"13\"/>\n        <text class=\"marker-score\" text-anchor=\"middle\" dy=\"4.2\">7</text>\n      </g>\n    </svg>\n  </div>\n\n  <div class=\"nerd-readout\">\n    <div>\n      <p class=\"ro-kicker\">NERD · nutrition ÷ energy</p>\n      <div class=\"ro-score\"><span class=\"big js-score\">7.0</span><span class=\"deno\">/ 10</span></div>\n      <p class=\"ro-verdict-word js-word\">Decent</p>\n      <p class=\"ro-verdict-line js-line\">Drag the marker, or pick a food below.</p>\n    </div>\n\n    <div class=\"ro-bars\">\n      <div class=\"ro-bar nutrition\">\n        <span class=\"lab\">Nutrition</span>\n        <span class=\"track\"><span class=\"fill js-nut-fill\"></span></span>\n        <span class=\"num js-nut-num\">50</span>\n      </div>\n      <div class=\"ro-bar energy\">\n        <span class=\"lab\">Energy</span>\n        <span class=\"track\"><span class=\"fill js-en-fill\"></span></span>\n        <span class=\"num js-en-num\">50</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"nerd-chips js-chips\"></div>\n<p class=\"nerd-hint\">Drag the dot anywhere · tap a food to fly it there</p>\n";
---

<div class="re-island" id="p-nerd" set:html={HTML}></div>

<style is:global>

#p-nerd {
  --nerd-pad: clamp(1rem, 3vw, 1.75rem);
  width: min(680px, 94vw);
  margin: 2.5rem auto;
  font-family: var(--font-body);
  color: var(--text-primary);
  -webkit-tap-highlight-color: transparent;
}

#p-nerd .nerd-stage {
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
  gap: clamp(0.9rem, 2.4vw, 1.6rem);
  align-items: stretch;
}
@media (max-width: 560px) {
  #p-nerd .nerd-stage { grid-template-columns: 1fr; }
}

/* ---- the plot ---- */
#p-nerd .nerd-plot-wrap {
  position: relative;
  border: 1px solid var(--hairline);
  border-radius: 6px;
  background: var(--bg-elevated);
  overflow: hidden;
}
#p-nerd svg.nerd-plot {
  display: block;
  width: 100%;
  height: auto;
  touch-action: none;
  cursor: grab;
}
#p-nerd svg.nerd-plot.is-grabbing { cursor: grabbing; }

#p-nerd .win-cell { fill: var(--derived-wash); }
#p-nerd .frame, #p-nerd .axis { stroke: var(--hairline); stroke-width: 1; }
#p-nerd .axis-tick { stroke: var(--hairline); stroke-width: 1; opacity: 0.55; }

#p-nerd .win-label {
  font-family: var(--font-mono);
  font-size: 8.4px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  fill: var(--derived);
}
#p-nerd .axis-label {
  font-family: var(--font-mono);
  font-size: 8.6px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  fill: var(--text-muted);
}
#p-nerd .axis-name {
  font-family: var(--font-mono);
  font-size: 8.2px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  fill: var(--text-secondary);
}

/* ghost food dots on the plane */
#p-nerd .ghost {
  fill: var(--surface);
  stroke: var(--hairline);
  stroke-width: 1;
  cursor: pointer;
  transition: r 0.18s ease, fill 0.18s ease;
}
#p-nerd .ghost:hover { fill: var(--depth-3); r: 5.4px; }
#p-nerd .ghost.is-active { fill: var(--text-muted); stroke: none; }

/* the marker */
#p-nerd .lead-line { stroke: var(--text-muted); stroke-width: 1; stroke-dasharray: 2 3; opacity: 0.5; }
#p-nerd .marker-halo { fill: var(--bg-elevated); stroke-width: 1.25; }
#p-nerd .marker-core { stroke: var(--bg-elevated); stroke-width: 1.5; }
#p-nerd .marker-score {
  font-family: var(--font-mono);
  font-weight: 600;
  font-size: 13px;
  fill: var(--bg-elevated);
  pointer-events: none;
}

/* pigment helpers (set on marker by JS) */
#p-nerd .tint-win   .marker-halo { stroke: var(--derived); }
#p-nerd .tint-win   .marker-core { fill: var(--derived); }
#p-nerd .tint-mid   .marker-halo { stroke: var(--contested); }
#p-nerd .tint-mid   .marker-core { fill: var(--contested); }
#p-nerd .tint-lose  .marker-halo { stroke: var(--open); }
#p-nerd .tint-lose  .marker-core { fill: var(--open); }

/* ---- readout panel ---- */
#p-nerd .nerd-readout {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 0.9rem;
  padding: var(--nerd-pad);
  border: 1px solid var(--hairline);
  border-radius: 6px;
  background: var(--bg-elevated);
}

#p-nerd .ro-kicker {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0 0 0.4rem;
}

#p-nerd .ro-score {
  display: flex;
  align-items: baseline;
  gap: 0.35rem;
  font-family: var(--font-mono);
  font-weight: 600;
  line-height: 0.92;
  color: var(--score-tint, var(--text-primary));
  transition: color 0.25s ease;
}
#p-nerd .ro-score .big { font-size: clamp(3rem, 11vw, 4.3rem); }
#p-nerd .ro-score .deno { font-size: 1.2rem; color: var(--text-muted); font-weight: 500; }

#p-nerd .ro-verdict-word {
  font-family: var(--font-display);
  font-size: clamp(1.25rem, 4vw, 1.7rem);
  font-weight: 500;
  color: var(--score-tint, var(--text-primary));
  margin: 0.1rem 0 0.15rem;
  transition: color 0.25s ease;
}
#p-nerd .ro-verdict-line {
  font-family: var(--font-body);
  font-size: 0.92rem;
  line-height: 1.45;
  color: var(--text-secondary);
  margin: 0;
  min-height: 2.6em;
}
#p-nerd .ro-verdict-line .food-name {
  font-style: italic;
  color: var(--text-primary);
}

/* the two component bars */
#p-nerd .ro-bars { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.2rem; }
#p-nerd .ro-bar { display: grid; grid-template-columns: 4.5em 1fr 2.2em; align-items: center; gap: 0.55rem; }
#p-nerd .ro-bar .lab {
  font-family: var(--font-mono);
  font-size: 8.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
}
#p-nerd .ro-bar .track {
  height: 6px;
  border-radius: 3px;
  background: var(--depth-3);
  overflow: hidden;
}
#p-nerd .ro-bar .fill { height: 100%; width: 0; border-radius: 3px; transition: width 0.32s cubic-bezier(.2,.7,.2,1); }
#p-nerd .ro-bar.nutrition .fill { background: var(--established); }
#p-nerd .ro-bar.energy .fill { background: var(--contested); }
#p-nerd .ro-bar .num {
  font-family: var(--font-mono);
  font-size: 9.5px;
  color: var(--text-secondary);
  text-align: right;
}

/* ---- food chips ---- */
#p-nerd .nerd-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-top: 1rem;
}
#p-nerd .chip {
  appearance: none;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.02em;
  color: var(--text-secondary);
  background: var(--surface);
  border: 1px solid var(--hairline);
  border-radius: 999px;
  padding: 0.34rem 0.78rem;
  cursor: pointer;
  transition: background 0.16s ease, color 0.16s ease, border-color 0.16s ease, transform 0.1s ease;
}
#p-nerd .chip:hover { background: var(--depth-3); color: var(--text-primary); }
#p-nerd .chip:active { transform: translateY(1px); }
#p-nerd .chip.is-active {
  color: var(--text-primary);
  border-color: var(--text-muted);
  background: var(--depth-3);
}
#p-nerd .chip .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 0.45rem; vertical-align: middle; }

#p-nerd .nerd-hint {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.04em;
  color: var(--text-muted);
  margin: 0.9rem 0 0;
  text-align: center;
}

@media (prefers-reduced-motion: no-preference) {
  #p-nerd .nerd-plot-wrap,
  #p-nerd .nerd-readout { animation: pn-rise 0.6s cubic-bezier(.2,.7,.2,1) backwards; }
  #p-nerd .nerd-readout { animation-delay: 0.08s; }
  #p-nerd .chip { animation: pn-rise 0.5s ease backwards; animation-delay: calc(0.18s + var(--ci, 0) * 0.04s); }
  @keyframes pn-rise { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
}

</style>

<script>
// @ts-nocheck
(function(){

const root = document.getElementById('p-nerd');
if (!root) return;

const svg     = root.querySelector('svg.nerd-plot');
const ghostsG = root.querySelector('.ghosts');
const marker  = root.querySelector('.marker');
const mScore  = root.querySelector('.marker-score');
const leadV   = root.querySelector('.lead-v');
const leadH   = root.querySelector('.lead-h');

const elScore = root.querySelector('.js-score');
const elWord  = root.querySelector('.js-word');
const elLine  = root.querySelector('.js-line');
const elNutF  = root.querySelector('.js-nut-fill');
const elEnF   = root.querySelector('.js-en-fill');
const elNutN  = root.querySelector('.js-nut-num');
const elEnN   = root.querySelector('.js-en-num');
const chipsEl = root.querySelector('.js-chips');

// plot geometry (matches the SVG viewBox)
const X0 = 48, X1 = 272, Y0 = 40, Y1 = 264;
const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));

// energy 0..100 -> x ; nutrition 0..100 -> y (inverted)
const enToX  = e => X0 + (clamp(e,0,100) / 100) * (X1 - X0);
const nutToY = n => Y1 - (clamp(n,0,100) / 100) * (Y1 - Y0);
const xToEn  = x => ((clamp(x,X0,X1) - X0) / (X1 - X0)) * 100;
const yToNut = y => ((Y1 - clamp(y,Y0,Y1)) / (Y1 - Y0)) * 100;

// THE SCORE: nutrition you get per unit of energy, squashed into 1..10.
function nerd(nut, en) {
  const e = Math.max(en, 5) / 100;     // energy floor avoids divide-by-near-zero
  const n = nut / 100;
  const ratio = n / e;                  // nutrition per energy
  const s = 1 + 9 * (1 - Math.exp(-1.05 * ratio));
  return clamp(s, 1, 10);
}

// preset foods: [energy 0..100, nutrition 0..100]
const FOODS = [
  { name: 'Broccoli',    en: 12, nut: 96 },
  { name: 'Salmon',      en: 46, nut: 82 },
  { name: 'Apple',       en: 36, nut: 70 },
  { name: 'White bread', en: 60, nut: 26 },
  { name: 'Donut',       en: 92, nut: 10 },
  { name: 'Soda',        en: 86, nut: 3  },
];

// verdict copy keyed by score band; {n} is replaced with the food name (or generic)
function verdict(score, foodName) {
  const s = score;
  const subj = foodName ? `<span class="food-name">${foodName}</span>` : 'This';
  let word, line;
  if (s >= 9.3) {
    word = 'A perfect 10';
    line = `${subj} — heaps of nourishment for almost no energy. This is the corner you want to live in.`;
  } else if (s >= 7.8) {
    word = 'Excellent';
    line = `${subj} pays its way: real nutrition, energy kept in check. Eat freely.`;
  } else if (s >= 6) {
    word = 'Decent';
    line = `${subj} earns its place — good food, just be aware of the energy it carries.`;
  } else if (s >= 4) {
    word = 'Middling';
    line = `${subj} is carrying more energy than nutrition. Fine sometimes; not the foundation.`;
  } else if (s >= 2.3) {
    word = 'Poor';
    line = `${subj} is mostly energy with little to show for it. A treat, not a staple.`;
  } else {
    word = 'A 1';
    line = `${subj} — all energy, no nutrition. The bottom-right corner: everything the NERD warns against.`;
  }
  return { word, line };
}

function tintClass(score) {
  if (score >= 6.5) return 'tint-win';
  if (score >= 3.5) return 'tint-mid';
  return 'tint-lose';
}
function tintVar(score) {
  if (score >= 6.5) return 'var(--derived)';
  if (score >= 3.5) return 'var(--contested)';
  return 'var(--open)';
}

let state = { en: 50, nut: 50 };

function render(foodName) {
  const en = state.en, nut = state.nut;
  const score = nerd(nut, en);
  const s1 = Math.round(score * 10) / 10;
  const x = enToX(en), y = nutToY(nut);

  // marker + lead lines
  marker.setAttribute('transform', `translate(${x} ${y})`);
  marker.setAttribute('class', `marker ${tintClass(score)}`);
  mScore.textContent = Math.round(score);
  leadV.setAttribute('x1', x); leadV.setAttribute('x2', x);
  leadV.setAttribute('y1', y); leadV.setAttribute('y2', Y1);
  leadH.setAttribute('x1', X0); leadH.setAttribute('x2', x);
  leadH.setAttribute('y1', y);  leadH.setAttribute('y2', y);

  // readout
  const tv = tintVar(score);
  root.querySelector('.ro-score').style.setProperty('--score-tint', tv);
  elWord.style.setProperty('--score-tint', tv);
  elScore.textContent = s1.toFixed(1);
  const v = verdict(score, foodName);
  elWord.textContent = v.word;
  elLine.innerHTML = v.line;

  // component bars
  elNutF.style.width = clamp(nut,0,100) + '%';
  elEnF.style.width  = clamp(en,0,100) + '%';
  elNutN.textContent = Math.round(nut);
  elEnN.textContent  = Math.round(en);
}

// ---- ghost dots on the plane ----
const ghostNodes = [];
FOODS.forEach((f, i) => {
  const g = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
  g.setAttribute('class', 'ghost');
  g.setAttribute('r', '4.2');
  g.setAttribute('cx', enToX(f.en));
  g.setAttribute('cy', nutToY(f.nut));
  g.addEventListener('click', (e) => { e.stopPropagation(); selectFood(i); });
  ghostsG.appendChild(g);
  ghostNodes.push(g);
});

// ---- food chips ----
const chipNodes = [];
FOODS.forEach((f, i) => {
  const b = document.createElement('button');
  b.className = 'chip';
  b.type = 'button';
  b.style.setProperty('--ci', i);
  const sc = nerd(f.nut, f.en);
  const dotColor = sc >= 6.5 ? 'var(--derived)' : sc >= 3.5 ? 'var(--contested)' : 'var(--open)';
  b.innerHTML = `<span class="dot" style="background:${dotColor}"></span>${f.name}`;
  b.addEventListener('click', () => selectFood(i));
  chipsEl.appendChild(b);
  chipNodes.push(b);
});

let activeFood = -1;
function setActiveChrome(i) {
  chipNodes.forEach((c, k) => c.classList.toggle('is-active', k === i));
  ghostNodes.forEach((g, k) => g.classList.toggle('is-active', k === i));
}

// animate the marker flying to a target
let animId = null;
function flyTo(targetEn, targetNut, foodName, foodIdx) {
  const startEn = state.en, startNut = state.nut;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (animId) cancelAnimationFrame(animId);
  if (reduce) { state.en = targetEn; state.nut = targetNut; render(foodName); return; }
  const dur = 460, t0 = performance.now();
  const ease = t => 1 - Math.pow(1 - t, 3);
  function step(now) {
    const t = clamp((now - t0) / dur, 0, 1);
    const e = ease(t);
    state.en  = startEn  + (targetEn  - startEn)  * e;
    state.nut = startNut + (targetNut - startNut) * e;
    render(foodName);
    if (t < 1) animId = requestAnimationFrame(step);
  }
  animId = requestAnimationFrame(step);
}

function selectFood(i) {
  const f = FOODS[i];
  activeFood = i;
  setActiveChrome(i);
  flyTo(f.en, f.nut, f.name, i);
}

// ---- dragging ----
function svgPoint(evt) {
  const r = svg.getBoundingClientRect();
  const sx = 320 / r.width, sy = 320 / r.height;
  return { x: (evt.clientX - r.left) * sx, y: (evt.clientY - r.top) * sy };
}
function moveTo(evt) {
  const p = svgPoint(evt);
  state.en  = xToEn(p.x);
  state.nut = yToNut(p.y);
  // a free drag clears the food identity
  if (activeFood !== -1) { activeFood = -1; setActiveChrome(-1); }
  render(null);
}
let dragging = false;
function onDown(evt) {
  dragging = true;
  svg.classList.add('is-grabbing');
  if (animId) { cancelAnimationFrame(animId); animId = null; }
  if (svg.setPointerCapture && evt.pointerId !== undefined) {
    try { svg.setPointerCapture(evt.pointerId); } catch (e) {}
  }
  moveTo(evt);
  evt.preventDefault();
}
function onMove(evt) { if (dragging) { moveTo(evt); evt.preventDefault(); } }
function onUp() { dragging = false; svg.classList.remove('is-grabbing'); }

svg.addEventListener('pointerdown', onDown);
svg.addEventListener('pointermove', onMove);
window.addEventListener('pointerup', onUp);
window.addEventListener('pointercancel', onUp);

// keyboard nudge for accessibility
svg.setAttribute('tabindex', '0');
svg.addEventListener('keydown', (e) => {
  const step = e.shiftKey ? 10 : 3;
  let used = true;
  if (e.key === 'ArrowLeft')  state.en  = clamp(state.en  - step, 0, 100);
  else if (e.key === 'ArrowRight') state.en  = clamp(state.en  + step, 0, 100);
  else if (e.key === 'ArrowUp')    state.nut = clamp(state.nut + step, 0, 100);
  else if (e.key === 'ArrowDown')  state.nut = clamp(state.nut - step, 0, 100);
  else used = false;
  if (used) { e.preventDefault(); if (activeFood !== -1){activeFood=-1;setActiveChrome(-1);} render(null); }
});

// opening pose: land on Broccoli so the win-corner sells itself
selectFood(0);

})();
</script>
