---
/**
 * SiteFooter — site-wide footer. Shows the version + git build number
 * (injected via astro.config.mjs). Mirrors the sibling sites.
 */
import { VERSION, BUILD } from '@/lib/version';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-name">Tom Cassidy — Comprehensivist &amp; Zengineer</span>
    <span class="footer-meta">
      <span class="version">{VERSION}</span>
      <span class="build">build {BUILD}</span>
      <span class="year">© {year}</span>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .footer-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
  }

  .version,
  .build {
    color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
