---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProgramWheel from '@/components/diagrams/ProgramWheel.svelte';
import { reasonableTeaching as program } from '@/lib/programs/reasonable-teaching';

// Reasonable Teaching — the programme, run on the 9×4 engine: two halves of four
// around the Self-Belief keystone (week 1). Same template family as the others.
export const prerender = true;

const pigClass: Record<string, string> = {
  established: 'is-established',
  derived: 'is-derived',
  open: 'is-open',
  contested: 'is-contested',
};
const hubPig = program.hub.pigment ?? 'established';
---

<BaseLayout title="Reasonable Teaching — Tom Cassidy" currentPage="programmes">
  <article class="program">
    <header class="prog-head">
      <p class="eyebrow">Reason-Ability · the teaching original</p>
      <h1 class="prog-title">{program.title}</h1>
      <p class="prog-lede">{program.blurb}</p>
    </header>

    <ProgramWheel program={program} client:visible />

    <section class="prose">
      <p>
        The programme runs on <strong>the 9×4</strong> — its engine: nine
        characteristics of exceptional teaching, taken one a week across the
        academic year. At the centre, the keystone the other eight rest on —
        <strong>{program.hub.algorithmName}</strong>. Tap a slice to meet its
        characteristic; press <strong>Play</strong> to walk the nine. (The full
        story of the engine is in the essay <a href="/writing/the-9x4">The 9×4</a>.)
      </p>
    </section>

    <!-- The keystone — Self-Belief (week 1). -->
    <section class="domain keystone">
      <div class="domain-head">
        <h2 class={`domain-name ${pigClass[hubPig]}`}>{program.hub.algorithmName}</h2>
        <p class="domain-q">{program.hub.kicker}</p>
      </div>
      <ol class="focuses">
        <li class="focus">
          <span class={`focus-wk ${pigClass[hubPig]}`}>Week {program.hub.numeral}</span>
          <div class="focus-body">
            <h3 class="focus-name">The keystone</h3>
            <p class="focus-wisdom">{program.hub.coach.wisdom}</p>
          </div>
        </li>
      </ol>
    </section>

    {program.domains.map((domain) => (
      <section class="domain" data-pig={domain.pigment}>
        <div class="domain-head">
          <h2 class={`domain-name ${pigClass[domain.pigment]}`}>{domain.name}</h2>
          <p class="domain-q">{domain.question}</p>
        </div>
        <ol class="focuses">
          {domain.focuses.map((f) => (
            <li class="focus">
              <span class={`focus-wk ${pigClass[domain.pigment]}`}>Week {f.week}</span>
              <div class="focus-body">
                <h3 class="focus-name">{f.name}</h3>
                <p class="focus-wisdom">{f.coach.wisdom}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}

    <footer class="prog-foot">
      <p>
        The teaching original that the whole family grew from — Franklin's “one
        thing at a time,” used to train over 130,000 teachers since 1994. Rendered
        here through the same <code>ProgramWheel</code> as every other programme,
        from one data file. The wisdom lines are draft coach copy.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .program { max-width: 820px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
  .prog-head { margin-bottom: 1rem; }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
  }
  .prog-title {
    font-family: var(--font-display); font-optical-sizing: auto;
    font-size: clamp(2.6rem, 7vw, 4rem); font-weight: 420; letter-spacing: -0.02em;
    color: var(--text-primary); margin: 0.4rem 0 0.6rem; line-height: 1;
  }
  .prog-lede {
    font-family: var(--font-body); font-style: italic;
    font-size: clamp(1.2rem, 2.4vw, 1.5rem); line-height: 1.45;
    color: var(--text-secondary); max-width: 46ch;
  }
  .prose { font-family: var(--font-body); font-size: 1.1rem; line-height: 1.7; color: var(--text-secondary); max-width: 62ch; margin: 1rem auto; }
  .prose strong { color: var(--text-primary); font-weight: 600; }
  .prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }

  .domain { margin-top: 3.5rem; padding-top: 1.5rem; border-top: 1px solid var(--hairline); }
  .keystone { border-top-width: 2px; }
  .domain-head { display: flex; align-items: baseline; gap: 0.9rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .domain-name {
    font-family: var(--font-display); font-optical-sizing: auto;
    font-size: clamp(1.5rem, 3.6vw, 2rem); font-weight: 460; letter-spacing: 0.02em; color: var(--text-primary);
  }
  .domain-q { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
  .is-established { color: var(--established); }
  .is-derived { color: var(--derived); }
  .is-open { color: var(--open); }
  .is-contested { color: var(--contested); }

  .focuses { list-style: none; display: flex; flex-direction: column; gap: 1.25rem; }
  .focus { display: grid; grid-template-columns: 5.5rem 1fr; gap: 0.5rem 1rem; align-items: start; }
  @media (max-width: 520px) { .focus { grid-template-columns: 1fr; gap: 0.2rem; } }
  .focus-wk { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em; color: var(--text-muted); padding-top: 0.35rem; white-space: nowrap; }
  .focus-name { font-family: var(--font-display); font-optical-sizing: auto; font-size: 1.3rem; font-weight: 480; color: var(--text-primary); line-height: 1.15; }
  .focus-wisdom { font-family: var(--font-body); font-size: 1.04rem; line-height: 1.6; color: var(--text-secondary); margin-top: 0.3rem; }

  .prog-foot {
    margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid var(--hairline);
    font-family: var(--font-body); font-style: italic; font-size: 1.02rem; line-height: 1.6;
    color: var(--text-muted); max-width: 62ch;
  }
  .prog-foot code { font-family: var(--font-mono); font-size: 0.82em; font-style: normal; }
</style>
