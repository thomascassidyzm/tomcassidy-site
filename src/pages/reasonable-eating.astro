---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProgramWheel from '@/kit/ProgramWheel.svelte';
import SubDiagram from '@/kit/primitives/SubDiagram.svelte';
import { reasonableEating as program } from '@/lib/programs/reasonable-eating';
import { assertValidProgram } from '@/kit';

assertValidProgram(program); // a malformed data file fails the build, not production

// The applied flagship as a real programme experience: the wheel as navigator,
// then its instrumented algorithms rendered straight from the data — any focus
// point carrying a `diagram` ref appears here, in domain order, with no
// per-diagram imports. Author a diagram in the data file and it shows up.
export const prerender = true;

const cycles = program.cycles;
const domainCount = program.domains.length;
const weeks = cycles * domainCount;

const instrumented = program.domains
  .map((d) => ({ ...d, live: d.focuses.filter((f) => f.diagram) }))
  .filter((d) => d.live.length > 0);
const instrumentCount = instrumented.reduce((s, d) => s + d.live.length, 0);
const COUNT_WORDS = ['none', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen'];
const countWord = COUNT_WORDS[instrumentCount] ?? String(instrumentCount);
---

<BaseLayout title="Reasonable Eating — Tom Cassidy" currentPage="programmes">
  <Fragment slot="head">
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#16140f" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Eating" />
  </Fragment>

  <article class="program">
    <header class="prog-head">
      <p class="eyebrow">Reason-Ability · an applied programme</p>
      <h1 class="prog-title">{program.title}</h1>
      <p class="prog-lede">{program.blurb}</p>
      <div class="install-row">
        <button id="pwa-install" class="install-cta" type="button" hidden>↓ Install as an app</button>
        <button id="notify-cta" class="install-cta" type="button" hidden>🔔 Tom in your pocket</button>
        <p id="ios-hint" class="ios-hint" hidden>Add to Home Screen: tap <strong>Share</strong>, then <strong>“Add to Home Screen.”</strong></p>
        <p id="notify-status" class="ios-hint" hidden></p>
      </div>
    </header>

    <!-- The wheel: diagram, navigator and coach in one. -->
    <ProgramWheel program={program} client:visible />

    <section class="prose">
      <p>
        Thirteen reasonable algorithms — one always-on focus at the centre
        (<strong>{program.hub.algorithmName}</strong>) and twelve that you take
        <em>one&nbsp;at&nbsp;a&nbsp;time</em>, a week each, cycling the four
        domains. {weeks} weeks to a lap, four laps to the year. No willpower
        marathon; just this week's one thing, done reasonably, until it's simply
        how you eat. Tap any slice above to meet its algorithm; press
        <strong>Play</strong> to watch the focus walk the weeks.
      </p>
    </section>

    <!-- Every instrumented algorithm, straight from the data, in domain order. -->
    {
      instrumented.map((d) => (
        <section class="domain" style={`--pig: var(--${d.pigment})`}>
          <p class="domain-kicker">{d.question}</p>
          {d.live.map((f) => (
            <>
              <div class="algo">
                <h2 class="algo-title">
                  <span class="wk">Week {f.week}</span> {f.name}
                </h2>
                <p class="algo-wisdom">{f.coach.wisdom}</p>
              </div>
              <SubDiagram
                client:visible
                diagram={f.diagram!}
                context={{ programTitle: program.title, week: f.week, domain: d.name, pigment: d.pigment }}
              />
            </>
          ))}
        </section>
      ))
    }

    <footer class="prog-foot">
      <p>
        That's {countWord} of the thirteen made interactive. The rest — and the
        “coach in your pocket” that nudges you to this week's focus — are the
        same wheel, the same data, read different ways.
      </p>
    </footer>
  </article>

  <script>
    // Tier-0 PWA: register the offline service worker (scoped to this
    // programme only) and wire a quiet install affordance.
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker
          .register('/sw.js', { scope: '/reasonable-eating' })
          .catch(() => {});
      });
    }
    (function () {
      const btn = document.getElementById('pwa-install');
      const iosHint = document.getElementById('ios-hint');
      let deferred: any = null;
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferred = e;
        if (btn) btn.hidden = false;
      });
      btn?.addEventListener('click', async () => {
        if (!deferred) return;
        deferred.prompt();
        await deferred.userChoice;
        deferred = null;
        if (btn) btn.hidden = true;
      });
      window.addEventListener('appinstalled', () => {
        if (btn) btn.hidden = true;
      });
      // iOS Safari has no beforeinstallprompt — show a manual hint instead,
      // unless already running installed (standalone).
      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
      const standalone =
        window.matchMedia('(display-mode: standalone)').matches ||
        (navigator as any).standalone === true;
      if (isIOS && !standalone && iosHint) iosHint.hidden = false;
    })();

    // ——————————————————————————————————————————————————————————————————————
    // Tom in your pocket — request notification permission and register a web
    // push subscription with the server. The same start date the wheel keeps in
    // localStorage is sent along, so the server computes the SAME "this week".
    // ——————————————————————————————————————————————————————————————————————
    (function () {
      const cta = document.getElementById('notify-cta') as HTMLButtonElement | null;
      const status = document.getElementById('notify-status');
      const ENROLL_KEY = 're-enrol:reasonable-eating';
      const pushOK = 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;
      if (!cta || !pushOK) return;

      function say(msg: string) {
        if (status) {
          status.textContent = msg;
          status.hidden = false;
        }
      }

      // Already granted + subscribed? Keep the button quiet.
      if (Notification.permission === 'granted') {
        cta.textContent = '🔔 Pocket coach on';
      }
      cta.hidden = false;

      // base64url VAPID key → Uint8Array for applicationServerKey.
      function urlBase64ToUint8Array(base64String: string) {
        const padding = '='.repeat((4 - (base64String.length % 4)) % 4);
        const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
        const raw = atob(base64);
        const out = new Uint8Array(raw.length);
        for (let i = 0; i < raw.length; i++) out[i] = raw.charCodeAt(i);
        return out;
      }

      cta.addEventListener('click', async () => {
        try {
          cta.disabled = true;
          say('Asking permission…');
          const perm = await Notification.requestPermission();
          if (perm !== 'granted') {
            say('No nudges — that’s fine. Tap again whenever you’re ready.');
            cta.disabled = false;
            return;
          }

          const reg = await navigator.serviceWorker.register('/sw.js', { scope: '/reasonable-eating' });
          await navigator.serviceWorker.ready;

          const res = await fetch('/api/push/vapid');
          if (!res.ok) throw new Error('Push isn’t configured on the server yet.');
          const { publicKey } = await res.json();

          let sub = await reg.pushManager.getSubscription();
          if (!sub) {
            sub = await reg.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: urlBase64ToUint8Array(publicKey),
            });
          }

          // The wheel's enrolment date is the program start; default to now.
          const raw = localStorage.getItem(ENROLL_KEY);
          const startMs = raw ? parseInt(raw, 10) : Date.now();
          if (!raw) localStorage.setItem(ENROLL_KEY, String(startMs));

          const save = await fetch('/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subscription: sub.toJSON(), startMs }),
          });
          const out = await save.json();
          if (!save.ok) throw new Error(out.error || 'Could not subscribe.');

          cta.textContent = '🔔 Pocket coach on';
          say('You’re set. I’ll bring this week’s one thing to mind, gently, a couple of times a day.');
        } catch (e) {
          say((e as Error).message || 'Something went wrong — try again.');
          cta.disabled = false;
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .program {
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .prog-head { margin-bottom: 1rem; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }
  .prog-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: clamp(2.6rem, 7vw, 4rem);
    font-weight: 420;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0.4rem 0 0.6rem;
    line-height: 1;
  }
  .prog-lede {
    font-family: var(--font-body);
    font-style: italic;
    font-size: clamp(1.2rem, 2.4vw, 1.5rem);
    line-height: 1.45;
    color: var(--text-secondary);
    max-width: 40ch;
  }

  .install-row { margin-top: 1.1rem; min-height: 1px; }
  .install-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--derived);
    background: var(--derived-wash);
    border: 1px solid var(--derived);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .install-cta:hover { background: var(--derived-chip); }
  .ios-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--text-muted);
    border: 1px dashed var(--hairline);
    border-radius: 8px;
    padding: 0.6rem 0.85rem;
    max-width: 40ch;
  }
  .ios-hint strong { color: var(--text-secondary); font-weight: 500; }

  .prose {
    font-family: var(--font-body);
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 62ch;
    margin: 1rem auto 1rem;
  }
  .prose strong { color: var(--text-primary); font-weight: 600; }

  .domain {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
  }
  .domain-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 0.5rem;
    color: var(--pig); /* the domain's pigment arrives from data via the --pig channel */
  }

  .algo { max-width: 62ch; margin: 2.5rem auto 0; }
  .algo-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: clamp(1.5rem, 3.2vw, 2rem);
    font-weight: 460;
    color: var(--text-primary);
    line-height: 1.15;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }
  .algo-title .wk {
    font-family: var(--font-mono);
    font-size: 0.62em;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .algo-wisdom {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 0.6rem;
  }

  .prog-foot {
    margin-top: 4.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 62ch;
  }
</style>
