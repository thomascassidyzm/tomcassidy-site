---
import { reasonableEating as program } from '@/lib/programs/reasonable-eating';
import { todaysFocus } from '@/lib/today';

// The everyday PRACTICE screen — and the page a push notification opens.
// It shows ONE thing: this week's focus. Computed fresh on each request so it
// always reflects the live calendar week, never a stale build.
export const prerender = false;

const { week, totalWeeks, focus, domain } = todaysFocus(program);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>This week · {program.title}</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#16140f" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Eating" />
  </head>
  <body>
    <main class="today">
      <p class="week">Week {week} of {totalWeeks}{domain ? ` · ${domain}` : ''}</p>
      <h1 class="focus">{focus.name}</h1>
      <p class="line">{focus.coach.wisdom}</p>
    </main>

    <style>
      :root {
        color-scheme: dark;
      }
      html,
      body {
        margin: 0;
        height: 100%;
        background: #16140f;
        color: #f3efe6;
        font-family: ui-serif, Georgia, 'Times New Roman', serif;
        -webkit-font-smoothing: antialiased;
      }
      .today {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.5rem;
        max-width: 34rem;
        margin: 0 auto;
        padding: 2rem 1.75rem calc(2rem + env(safe-area-inset-bottom));
        box-sizing: border-box;
      }
      .week {
        margin: 0;
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #a39b86;
      }
      .focus {
        margin: 0;
        font-size: clamp(2.4rem, 9vw, 3.6rem);
        line-height: 1.05;
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .line {
        margin: 0;
        font-size: clamp(1.15rem, 4.5vw, 1.4rem);
        line-height: 1.5;
        color: #d8d2c4;
      }
    </style>
  </body>
</html>
