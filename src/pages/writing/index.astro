---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EssayCard from '@/components/EssayCard.astro';

export const prerender = true;

const essays = (await getCollection('essays')).filter((e) => !e.data.draft);
essays.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// The four series are the primary organising groups ("bigger groupings").
// Granular topics are no longer filter chips — they live on the cards and are
// reachable through the search box, which matches title + summary + topics.
const SERIES_ORDER = [
  'The Art of Learning',
  'Philosophy & Leadership',
  'Reason-Ability',
  'The Format',
];
const present = new Set(essays.map((e) => e.data.series).filter(Boolean) as string[]);
const seriesList = SERIES_ORDER.filter((s) => present.has(s));
// Future-proofing: any series not in the explicit order is appended alphabetically.
for (const s of [...present].sort()) if (!seriesList.includes(s)) seriesList.push(s);

// Lowercased search blob per essay: title + summary + topics + series.
const searchBlob = (e: (typeof essays)[number]): string =>
  [e.data.title, e.data.summary, (e.data.topics ?? []).join(' '), e.data.series ?? '']
    .join(' ')
    .toLowerCase();
---

<BaseLayout title="Writing — Tom Cassidy" currentPage="writing">
  <section class="section">
    <header class="page-head">
      <h1 class="page-title">Writing</h1>
      <p class="page-sub">Essays and notes. Thinking out loud.</p>
    </header>

    <div class="controls">
      <label class="search" for="writing-search">
        <span class="search-icon" aria-hidden="true">⌕</span>
        <input
          id="writing-search"
          type="search"
          class="search-input"
          placeholder="Search writing…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search writing"
        />
      </label>

      {seriesList.length > 0 && (
        <div class="filters" id="filters">
          <button class="filter active" data-filter-value="">All</button>
          {seriesList.map((s) => (
            <button class="filter" data-filter-value={s}>{s}</button>
          ))}
        </div>
      )}
    </div>

    <div class="essay-grid" id="essay-grid">
      {essays.map((e) => (
        <div
          class="grid-item"
          data-series={e.data.series ?? ''}
          data-search={searchBlob(e)}
        >
          <EssayCard
            title={e.data.title}
            slug={e.data.slug}
            summary={e.data.summary}
            date={e.data.date}
            topics={e.data.topics}
            epistemicStatus={e.data.epistemicStatus}
            series={e.data.series}
          />
        </div>
      ))}
    </div>

    <p class="empty" id="empty-state" hidden>
      Nothing matches that.
      <button class="empty-clear" id="empty-clear" type="button">Clear</button>
    </p>
  </section>
</BaseLayout>

<style>
  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    font-weight: 420;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .page-sub {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .controls {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin: 2.25rem 0;
  }

  .search {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    max-width: 420px;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--hairline);
    border-radius: 6px;
    background: transparent;
    transition: border-color 0.2s ease;
  }
  .search:focus-within { border-color: var(--text-muted); }

  .search-icon {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1;
  }

  .search-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }
  .search-input::placeholder { color: var(--text-muted); }
  /* Hide the native search clear affordance for a cleaner look. */
  .search-input::-webkit-search-cancel-button { -webkit-appearance: none; appearance: none; }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
  }

  .filter {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.8rem;
    border-radius: 5px;
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .filter:hover { color: var(--text-secondary); border-color: var(--text-muted); }
  .filter.active { border-color: var(--established); color: var(--established); background: var(--established-wash); }

  .essay-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .grid-item.hidden { display: none; }

  .empty {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin-top: 2.5rem;
  }
  .empty-clear {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    margin-left: 0.4rem;
    border-radius: 5px;
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .empty-clear:hover { color: var(--text-secondary); border-color: var(--text-muted); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter'));
    const items = Array.from(document.querySelectorAll<HTMLElement>('.grid-item'));
    const search = document.getElementById('writing-search') as HTMLInputElement | null;
    const empty = document.getElementById('empty-state') as HTMLElement | null;
    const emptyClear = document.getElementById('empty-clear');

    let activeSeries = '';
    let query = '';

    function apply() {
      let visible = 0;
      items.forEach((item) => {
        const seriesOk = activeSeries === '' || item.dataset.series === activeSeries;
        const queryOk = query === '' || (item.dataset.search ?? '').includes(query);
        const show = seriesOk && queryOk;
        item.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    }

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        filters.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeSeries = btn.getAttribute('data-filter-value') ?? '';
        apply();
      });
    });

    search?.addEventListener('input', () => {
      query = (search.value ?? '').trim().toLowerCase();
      apply();
    });

    emptyClear?.addEventListener('click', () => {
      query = '';
      activeSeries = '';
      if (search) search.value = '';
      filters.forEach((b) => b.classList.remove('active'));
      filters[0]?.classList.add('active');
      apply();
    });
  });
</script>
