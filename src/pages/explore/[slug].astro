---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProgramWheel from '@/kit/ProgramWheel.svelte';
import ExploreProgram from '@/components/ExploreProgram.astro';
import { ALL_PROGRAMS, programBySlug } from '@/lib/programs';
import { assertValidProgram } from '@/kit';

// STUDY mode — one Explore page per programme, generated from the registry.
// The everyday Today surface is PRACTICE mode; this is where a reader sits
// down with the whole reasoning before committing to the thirteen.
export const prerender = true;

export function getStaticPaths() {
  return ALL_PROGRAMS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const program = programBySlug(slug!);
if (!program) throw new Error(`Explore: no programme for slug "${slug}"`);
assertValidProgram(program);
---

<BaseLayout title={`Explore ${program.title} — ${program.byline ?? 'Tom Cassidy'}`} currentPage="programmes">
  <article class="explore-page">
    <header class="prog-head">
      <p class="eyebrow">Explore the programme · study mode{program.byline ? ` · ${program.byline}` : ''}</p>
      <h1 class="prog-title">{program.title}</h1>
      <p class="prog-lede">{program.blurb}</p>
    </header>

    <!-- The wheel as the navigator into the deep dives below. -->
    <ProgramWheel program={program} deepDiveHref="" client:visible />

    <ExploreProgram program={program} />

    <footer class="prog-foot">
      <p>
        This is study mode — the full reasoning, so the choice of focus points
        earns your trust. The everyday surface asks only for this week’s one
        thing. Reason × reasonable: have a reason, make it reasonable, and let
        the year do the compounding.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .explore-page { max-width: 820px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }

  .prog-head { margin-bottom: 1rem; }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
  }
  .prog-title {
    font-family: var(--font-display); font-optical-sizing: auto;
    font-size: clamp(2.6rem, 7vw, 4rem); font-weight: 420; letter-spacing: -0.02em;
    color: var(--text-primary); margin: 0.4rem 0 0.6rem; line-height: 1;
  }
  .prog-lede {
    font-family: var(--font-body); font-style: italic;
    font-size: clamp(1.2rem, 2.4vw, 1.5rem); line-height: 1.45;
    color: var(--text-secondary); max-width: 44ch;
  }

  .prog-foot {
    margin-top: 4.5rem; padding-top: 1.5rem; border-top: 1px solid var(--hairline);
    font-family: var(--font-body); font-style: italic; font-size: 1.02rem;
    line-height: 1.6; color: var(--text-muted); max-width: 62ch;
  }
</style>
