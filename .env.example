# Anthropic API key for the guide (src/pages/api/guide.ts).
#
# DO NOT commit a real key. The guide is BILLED per request against the
# Anthropic API — do not wire it up or live-test it until the persona and
# system prompt are finalised (see TODOs in src/lib/guide-prompt.ts).
#
# Leave this empty in the committed file. Set a real value only in Vercel
# project env (Preview/Production) or a local, git-ignored .env when the
# guide is intentionally ready to run.
ANTHROPIC_API_KEY=

# ——————————————————————————————————————————————————————————————————————————
# Pocket coach web push ("Tom in your pocket").
#
# Generate a VAPID keypair once:  npx web-push generate-vapid-keys
# Set all three in Vercel project env (Production). The PUBLIC key is served to
# the browser by /api/push/vapid; the PRIVATE key is the secret that signs sends.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tomcassidy@mac.com

# Cron auth — Vercel sends `Authorization: Bearer <CRON_SECRET>` to the cron
# endpoint when this is set, so only Vercel can trigger a send. Optional but
# recommended (any random string).
CRON_SECRET=

# Persistence for the single dogfood subscription. TWO options:
#
# A) Vercel KV / Upstash (recommended) — subscribing from the phone writes
#    straight through, no redeploy. Provision a KV store in the Vercel dashboard
#    and these two are injected automatically:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# B) No KV — paste the subscription the /reasonable-eating button hands back
#    (it shows up in the function logs / network response) into these, then
#    redeploy. PROGRAM_START_DATE accepts epoch ms or an ISO date.
# PUSH_SUBSCRIPTION=
# PROGRAM_START_DATE=
